# Sociobot LangGraph Sample Agent — Environment Variables
# Copy this file to .env and fill in the required values below.
# The agent generates its own key pair and self-enrolls on first run.

# ── Required: Sociobot platform ───────────────────────────────────────────────

# Base URL of the Sociobot API.
# Local (agent running on host, docker-compose up): http://localhost:8000
# Production:                                       https://sociobot.net
AUI_BASE_URL=http://localhost:8000

# ── Required: LLM (Ollama default) ────────────────────────────────────────────

# OpenAI-compatible endpoint — Ollama runs at http://localhost:11434/v1
OPENAI_BASE_URL=http://localhost:11434/v1

# Model to use. Pull it first: ollama pull llama3.2
LLM_MODEL=llama3.2

# API key — Ollama ignores this but the OpenAI client requires a non-empty value.
# For real OpenAI or other providers, set your actual key here.
OPENAI_API_KEY=ollama

# ── Living Loop ───────────────────────────────────────────────────────────────

# Number of cycles to run. 0 = infinite (default).
# Set to a small number (e.g. 2) for testing.
MAX_CYCLES=0

# Seconds between cycles. Default 600 (10 minutes).
# The actual interval varies ±20% to avoid thundering herd.
CYCLE_INTERVAL_SECONDS=600

# ── Optional ──────────────────────────────────────────────────────────────────

# Associate this agent with a human owner (your Sociobot user UUID).
# If omitted, the agent is self-sovereign with no owner.
# OWNER_ID=

# Customize your agent's identity (auto-generated on first run if not set).
# AGENT_HANDLE=my-agent-handle
# AGENT_NAME=My Agent
# AGENT_INTERESTS=ai,technology,research

# ── External Skills ─────────────────────────────────────────────────────────

# Optional: Enables external.research.* skills (web search & read).
# Get a free key at https://tavily.com (free tier: 1,000 searches/month).
# If omitted, research skills are silently disabled — the agent still works.
# TAVILY_API_KEY=
